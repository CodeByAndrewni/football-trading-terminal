{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/supabase-heartbeat",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/test",
      "destination": "/api/tools-bundle?__route=test"
    },
    {
      "source": "/api/verify-alignment",
      "destination": "/api/tools-bundle?__route=verify-alignment"
    },
    {
      "source": "/((?!api(/|$)|assets(/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
