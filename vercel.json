{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/matches",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/supabase-heartbeat",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/translate-names?window=today",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/translate-names?window=tomorrow",
      "schedule": "0 16 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/test",
      "destination": "/api/tools-bundle?__route=test"
    },
    {
      "source": "/api/verify-alignment",
      "destination": "/api/tools-bundle?__route=verify-alignment"
    },
    {
      "source": "/((?!api\\/.*|assets\\/.*).*)",
      "destination": "/index.html"
    }
  ]
}
