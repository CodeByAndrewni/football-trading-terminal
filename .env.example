# 足球交易决策终端 - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# API-Football v3 API Key (主数据源)
# 获取地址: https://www.api-football.com/
VITE_FOOTBALL_API_KEY=your_api_key_here
FOOTBALL_API_KEY=your_api_key_here

# The Odds API Key - REMOVED (500/month quota too low)
# THE_ODDS_API_KEY=

# Sportmonks API Key (第三数据源 - 支持中文)
# 获取地址: https://www.sportmonks.com/football-api/
# 14天试用期, 支持 locale=zh 中文翻译
SPORTMONKS_API_KEY=your_sportmonks_api_key_here

# ============================================
# Vercel 后端聚合层配置
# ============================================

# Vercel KV (Redis) - 在 Vercel 控制台创建 KV 存储后自动注入
# 文档: https://vercel.com/docs/storage/vercel-kv
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Cron Job 安全密钥 (可选)
# 用于验证 Cron 请求来源
# 生成方式: openssl rand -hex 32
CRON_SECRET=

# ============================================
# AI 问答（DeepSeek / Perplexity）
# 供服务端接口 POST /api/ai/chat 使用
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DeepSeek Chat Completions URL（默认即可，无需修改）
# DEEPSEEK_CHAT_URL=https://api.deepseek.com/chat/completions

# Agent：单次对话内 API-Football 调用上限（kv_list 不计入）
AI_AGENT_MAX_FOOTBALL_CALLS=20
# Agent：模型↔工具 最大往返轮次（每轮一次 Chat Completions）
AI_AGENT_MAX_TOOL_ROUNDS=4

# Perplexity 目前是可选能力（如你在前端/请求中启用）
# 需要在对应逻辑里显式调用才会生效
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# Local AI API server port（本地联调用）
# 如果你本机 3000 被占用，可以把它改成 3001 等空闲端口。
AI_API_PORT=3001
